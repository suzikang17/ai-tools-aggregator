---
import toolsData from "../../data/tools.json";
import pulseData from "../../data/market-pulse.json";
import App from "../components/App";
import "../styles/global.css";

const { metadata: toolsMeta, tools } = toolsData;
const { metadata: pulseMeta, tools: pulseTools } = pulseData;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>AI Tools Aggregator</title>
</head>
<body>
  <div class="container">
    <header>
      <h1>AI Tools Aggregator</h1>
    </header>
    <App
      client:load
      tools={tools}
      toolsLastUpdated={toolsMeta.lastUpdated}
      pulseTools={pulseTools}
      pulseLastRefreshed={pulseMeta.lastRefreshed}
    />
  </div>
</body>
</html>
