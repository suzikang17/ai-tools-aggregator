---
import toolsData from "../../data/tools.json";
import ToolsGrid from "../components/ToolsGrid";
import "../styles/global.css";

const { metadata, tools } = toolsData;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>AI Tools Aggregator</title>
</head>
<body>
  <div class="container">
    <header>
      <h1>AI Tools Aggregator</h1>
    </header>
    <ToolsGrid
      client:load
      tools={tools}
      lastUpdated={metadata.lastUpdated}
    />
  </div>
</body>
</html>
